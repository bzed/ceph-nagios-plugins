#!/usr/bin/make -f
# -*- makefile -*-

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

%:
	dh "$@" --with python3

# install in official directories
override_dh_auto_install:
	dh_auto_install -- prefix=/usr sysconfdir=/etc

# Override dh_python3 as we install scripts, not Python modules
override_dh_python3:
	# Do nothing - scripts are installed directly


